# NQAI Voice — server environment template.
# Copy to .env, fill in, and source before launching. .env itself is gitignored.

# Comma-separated bearer tokens that the server accepts. Generate via:
#   python -c "import secrets; print('nqai-' + secrets.token_urlsafe(24))"
NQAI_API_KEYS=

# Set to "false" only for local dev — production must keep auth on.
NQAI_REQUIRE_AUTH=true

# Device for the VoxCPM2 backend: "auto" (CUDA→MPS→CPU), "cuda", "cpu".
# VoxCPM2 needs ~8 GB VRAM and a CUDA 12 GPU for real-time inference.
NQAI_DEVICE=auto

# HF model id. The `BaseSynthEngine` adapter pattern keeps the API stable
# if you later swap to a Türkçe-SFT'd checkpoint — see src/server/engine.py.
NQAI_MODEL_ID=openbmb/VoxCPM2

# Optional VoxCPM2 LoRA adapter for demo / single-adapter deployments.
# Point this at a checkpoint directory containing lora_config.json and
# lora_weights.safetensors. For per-voice production adapters, prefer the
# voice manifest `adapter:` field instead of this global value.
# NQAI_LORA_PATH=/content/drive/MyDrive/nqai-voice/finetune/neeko-proto-v0/checkpoints/lora/latest
# NQAI_LORA_CONFIG_PATH=/content/drive/MyDrive/nqai-voice/finetune/neeko-proto-v0/checkpoints/lora/latest/lora_config.json

# Inference knobs. Lower cfg (1.3-1.6) tends to reduce voice drift for the
# current NEEKO prototype; higher values can exaggerate character/emotion.
NQAI_CFG_VALUE=1.5
NQAI_INFERENCE_TIMESTEPS=20
NQAI_OPTIMIZE=false

# Filesystem layout. Defaults resolve under the repo root.
# NQAI_VOICES_DIR=/path/to/configs/voices
# NQAI_REFERENCE_DIR=/path/to/data/reference-audio

# Limits.
NQAI_MAX_CHARS=4000
NQAI_ENROLL_MAX_MB=20
NQAI_REF_TRIM_SECONDS=15.0

# Reference audio is resampled to 16 kHz mono for VoxCPM2; output is 48 kHz
# via the model's AudioVAE V2 decoder.
NQAI_REF_SR=16000
NQAI_TARGET_SR=48000

# ---------- Object storage (Cloudflare R2, S3-compatible API) -------------
# R2 dashboards: https://dash.cloudflare.com/ → R2 → Manage R2 API Tokens.
# Account ID is the same one shown in your Cloudflare dashboard URL.
# Endpoint is auto-derived: https://<NQAI_R2_ACCOUNT_ID>.r2.cloudflarestorage.com
NQAI_R2_ACCOUNT_ID=
NQAI_R2_BUCKET=
NQAI_R2_ACCESS_KEY_ID=
NQAI_R2_SECRET_ACCESS_KEY=
# Local disk cache for downloaded reference audio. Faz C+ moves this to
# an emptyDir volume in Kubernetes for ephemeral cache.
NQAI_R2_CACHE_DIR=/tmp/nqai-r2-cache

# CORS — "*" is fine while the only client is your own dashboard; tighten before
# exposing to third-party developers.
NQAI_CORS_ORIGINS=*

# Uvicorn port (when launched via `nqai-voice-server` console script).
NQAI_PORT=8000

# ---------- Admin / operator JWT signing -----------------------------------
# Used by src/server/admin/ to sign operator login cookies (HS256). MUST be
# at least 32 chars; production: rotate quarterly. Generate via:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED — docker-compose.dev.yaml refuses to start without this.
NQAI_JWT_SECRET=

# Set to "true" in production (HTTPS only) so the admin-session cookie is
# marked Secure. "false" for local docker compose (no TLS).
NQAI_COOKIE_SECURE=false

# ---------- Database / Redis URLs (compose overrides these) ----------------
# Local docker compose sets these from service names; only override when
# running gateway / worker against a non-compose Postgres / Redis (e.g.
# Colab notebook reaching out to a remote db, or production cluster).
# NQAI_DATABASE_URL=postgresql+asyncpg://nqai:nqai@localhost:5432/nqai_voice
# NQAI_REDIS_URL=redis://localhost:6379/0

# ---------- Worker-only tunables (consumer / DLQ / warmup) -----------------
# Most have safe defaults; uncomment to override.
# NQAI_WORKER_MODE=consumer            # "consumer" (default) or "smoke"
# NQAI_WORKER_DEVICE=cuda              # cuda / cpu / auto; worker-only
# NQAI_WORKER_CONSUMER_NAME=worker-1   # unique per worker pod
# NQAI_WORKER_BLOCK_MS=2000            # XREADGROUP block timeout
# NQAI_WORKER_MAX_RETRIES=3            # job retries before DLQ
# NQAI_WORKER_DLQ_STREAM=nqai.tts.jobs.dlq
# NQAI_WORKER_XAUTOCLAIM_INTERVAL_S=60 # PEL stuck-job reclaim period
# NQAI_WARMUP_ON_BOOT=true             # eager-load VoxCPM2 at startup
# NQAI_LORA_CACHE_SIZE=3               # per-worker LRU adapter cache
# NQAI_RESULT_STREAM_TTL_S=900         # async-result XADD MAXLEN ~900s

# ---------- Gateway tunables -----------------------------------------------
# Backpressure threshold — gateway returns 503 when queue depth exceeds
# (worker_capacity_total + headroom). Tune after first load_bench run.
# NQAI_QUEUE_DEPTH_LIMIT=200
