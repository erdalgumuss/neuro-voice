# NQAI Voice — server environment template.
# Copy to .env, fill in, and source before launching. .env itself is gitignored.

# Comma-separated bearer tokens that the server accepts. Generate via:
#   python -c "import secrets; print('nqai-' + secrets.token_urlsafe(24))"
NQAI_API_KEYS=

# Set to "false" only for local dev — production must keep auth on.
NQAI_REQUIRE_AUTH=true

# Device for the Chatterbox backend: "auto" (CUDA→MPS→CPU), "cuda", "cpu".
NQAI_DEVICE=auto

# HF model id. The adapter pattern lets you swap to VoxCPM2 later without
# touching the API layer — see src/server/engine.py.
NQAI_MODEL_ID=ResembleAI/chatterbox-multilingual

# Filesystem layout. Defaults resolve under the repo root.
# NQAI_VOICES_DIR=/path/to/configs/voices
# NQAI_REFERENCE_DIR=/path/to/data/reference-audio

# Limits.
NQAI_MAX_CHARS=4000
NQAI_ENROLL_MAX_MB=20
NQAI_REF_TRIM_SECONDS=15.0
NQAI_TARGET_SR=24000

# CORS — "*" is fine while the only client is your own dashboard; tighten before
# exposing to third-party developers.
NQAI_CORS_ORIGINS=*

# Uvicorn port (when launched via `nqai-voice-server` console script).
NQAI_PORT=8000
